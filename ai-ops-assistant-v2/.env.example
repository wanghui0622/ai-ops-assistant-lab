# ---------- LLM（Camel ChatAgent）----------
OPENAI_API_KEY=
# USE_MOCK_AGENTS=1

CAMEL_MODEL_NAME=gpt-4o-mini
CAMEL_TEMPERATURE=0.2

# ---------- Doris（不设 DORIS_HOST 则走内存 Mock OLAP）----------
# DORIS_USE_MOCK=1
DORIS_HOST=
DORIS_QUERY_PORT=9030
DORIS_USER=
DORIS_PASSWORD=
DORIS_DATABASE=

# ---------- SQL ----------
SQL_ROW_LIMIT=5000
SQL_EXPLAIN_VERBOSE=0

# ---------- OWL 缓存 ----------
WORKFLOW_CACHE=1
WORKFLOW_CACHE_MAX=256
